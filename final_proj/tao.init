&tao_design_lattice
  n_universes = 1
  design_lattice(1)%file = "output_racetrack.bmad"
/
&tao_params
  global%track_type = "beam"
/

! Sets custom plot page settings
&tao_plot_page
	plot_page%size = 400, 400
	plot_page%text_height = 8
	plot_page%n_curve_pts = 5000
/

&tao_start
  plot_file = "tao_plot.init" ! moved templates here
  beam_file = 'beam.init'
/
